    "Transmission_Temperature":{ "unit": "°C",     "min_normal": 65,    "max_normal": 115,  "warn_high": 130,  "critical_high": 145 },
    "Transmission_Pressure":   { "unit": "kPa",    "min_normal": 1200,  "max_normal": 2000, "warn_low": 800,   "critical_low": 400 },
    "Brake_Temperature":       { "unit": "°C",     "min_normal": 50,    "max_normal": 180,  "warn_high": 250,  "critical_high": 300 },
    "Brake_Pressure":          { "unit": "bar",    "min_normal": 80,    "max_normal": 160,  "warn_low": 40,    "critical_low": 20 },
    "Tire_Pressure_FL":        { "unit": "PSI",    "min_normal": 85,    "max_normal": 120,  "warn_low": 65,    "warn_high": 128, "critical_low": 50 },
    "Tire_Pressure_FR":        { "unit": "PSI",    "min_normal": 85,    "max_normal": 120,  "warn_low": 65,    "warn_high": 128, "critical_low": 50 },
    "Tire_Pressure_RL":        { "unit": "PSI",    "min_normal": 85,    "max_normal": 120,  "warn_low": 65,    "warn_high": 128, "critical_low": 50 },
    "Tire_Pressure_RR":        { "unit": "PSI",    "min_normal": 85,    "max_normal": 120,  "warn_low": 65,    "warn_high": 128, "critical_low": 50 },
    "Tire_Temperature":        { "unit": "°C",     "min_normal": 30,    "max_normal": 75,   "warn_high": 88,   "critical_high": 100 },
    "Suspension_Vibration":    { "unit": "g RMS",  "min_normal": 0.5,   "max_normal": 6.0,  "warn_high": 9.0,  "critical_high": 12.0 },
    "Overall_Vibration":       { "unit": "mm/s",   "min_normal": 1.0,   "max_normal": 7.0,  "warn_high": 10.0, "critical_high": 18.0 },
    "FFT_Peak":                { "unit": "mm/s",   "min_normal": 0.5,   "max_normal": 10.0, "warn_high": 15.0, "critical_high": 22.0 },
    "RMS_Vibration":           { "unit": "mm/s",   "min_normal": 0.5,   "max_normal": 6.0,  "warn_high": 8.0,  "critical_high": 14.0 },
    "Bearing_Temperature":     { "unit": "°C",     "min_normal": 50,    "max_normal": 90,   "warn_high": 110,  "critical_high": 130 },
    "Bearing_Vibration":       { "unit": "mm/s",   "min_normal": 0.3,   "max_normal": 4.0,  "warn_high": 7.0,  "critical_high": 12.0 },
    "Acoustic_Noise_Level":    { "unit": "dB(A)",  "min_normal": 70,    "max_normal": 95,   "warn_high": 100,  "critical_high": 108 },
    "Ultrasonic_Emission":     { "unit": "dBµV",   "min_normal": 0,     "max_normal": 30,   "warn_high": 50,   "critical_high": 70 },
    "Ambient_Temperature":     { "unit": "°C",     "min_normal": -20,   "max_normal": 45,   "warn_low": -15,   "warn_high": 48 },
    "Last_Service_Days":       { "unit": "days",   "min_normal": 0,     "max_normal": 90,   "warn_high": 80,   "critical_high": 100 },
    "Last_Service_Hours":      { "unit": "hours",  "min_normal": 0,     "max_normal": 500,  "warn_high": 450,  "critical_high": 550 },
    "Filter_Age":              { "unit": "hours",  "min_normal": 0,     "max_normal": 500,  "warn_high": 450,  "critical_high": 600 },
    "Oil_Age":                 { "unit": "hours",  "min_normal": 0,     "max_normal": 500,  "warn_high": 450,  "critical_high": 550 }
  },

  "failure_progression_windows": {
    "Hydraulic Pump Failure":  { "onset_days": 3,  "warning_hours": 72,  "critical_hours": 12 },
    "Bearing Wear":            { "onset_days": 6,  "warning_hours": 168, "critical_hours": 24 },
    "Engine Overheating":      { "onset_days": 2,  "warning_hours": 48,  "critical_hours": 6 },
    "Fuel System Failure":     { "onset_days": 1,  "warning_hours": 24,  "critical_hours": 4 },
    "Turbo Failure":           { "onset_days": 4,  "warning_hours": 96,  "critical_hours": 12 },
    "Transmission Failure":    { "onset_days": 5,  "warning_hours": 120, "critical_hours": 24 },
    "Brake Failure":           { "onset_days": 3,  "warning_hours": 48,  "critical_hours": 6 },
    "Tire Failure":            { "onset_days": 1.5,"warning_hours": 36,  "critical_hours": 4 },
    "Electrical Failure":      { "onset_days": 1,  "warning_hours": 12,  "critical_hours": 2 },
    "Cooling System Failure":  { "onset_days": 2,  "warning_hours": 48,  "critical_hours": 8 },
    "Sensor Failure":          { "onset_days": 0.5,"warning_hours": 6,   "critical_hours": 1 }
  }
}
