{
  "title": "PFMI Sensor Operating Ranges & Failure Thresholds",
  "description": "Normal operating envelopes and failure thresholds for all sensors in the wheel loader PFMI dataset. Based on OEM specifications for Cat 950GC, Volvo L120H, Komatsu WA380, and Hyundai HL960.",

  "sensor_ranges": {
    "Engine_RPM":              { "unit": "RPM",    "min_normal": 700,   "max_normal": 2300, "warn_low": 600,   "warn_high": 2400, "critical_high": 2600 },
    "Fuel_Rate":               { "unit": "L/hr",   "min_normal": 2,     "max_normal": 28,   "warn_high": 30,   "critical_high": 34 },
    "Fuel_Level":              { "unit": "%",      "min_normal": 15,    "max_normal": 100,  "warn_low": 10,    "critical_low": 5 },
    "Engine_Load":             { "unit": "0–1",    "min_normal": 0.05,  "max_normal": 0.90, "warn_high": 0.95, "critical_high": 1.0 },
    "Hydraulic_Load":          { "unit": "0–1",    "min_normal": 0.05,  "max_normal": 0.90, "warn_high": 0.95, "critical_high": 1.0 },
    "Bucket_Load":             { "unit": "tonnes", "min_normal": 0,     "max_normal": 3.4,  "warn_high": 3.5,  "critical_high": 3.8 },
    "Travel_Speed":            { "unit": "km/h",   "min_normal": 0,     "max_normal": 35,   "warn_high": 36,   "critical_high": 40 },
    "Coolant_Temperature":     { "unit": "°C",     "min_normal": 70,    "max_normal": 100,  "warn_high": 107,  "critical_high": 115 },
    "Oil_Temperature":         { "unit": "°C",     "min_normal": 80,    "max_normal": 115,  "warn_high": 120,  "critical_high": 130 },
    "Engine_Temperature":      { "unit": "°C",     "min_normal": 75,    "max_normal": 105,  "warn_high": 110,  "critical_high": 120 },
    "Oil_Pressure":            { "unit": "kPa",    "min_normal": 250,   "max_normal": 450,  "warn_low": 200,   "critical_low": 150 },
    "Coolant_Pressure":        { "unit": "bar",    "min_normal": 1.0,   "max_normal": 1.8,  "warn_low": 0.7,   "warn_high": 2.0, "critical_low": 0.5 },
    "Intake_Air_Temperature":  { "unit": "°C",     "min_normal": 20,    "max_normal": 65,   "warn_high": 70,   "critical_high": 80 },
