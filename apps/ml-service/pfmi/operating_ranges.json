    "Fuel_Pressure":           { "unit": "kPa",    "min_normal": 400,   "max_normal": 650,  "warn_low": 300,   "critical_low": 150 },
    "Air_Filter_Restriction":  { "unit": "%",      "min_normal": 0,     "max_normal": 60,   "warn_high": 75,   "critical_high": 90 },
